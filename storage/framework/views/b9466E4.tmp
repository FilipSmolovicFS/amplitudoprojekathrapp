        <input type="file"
               name="contracts_document"
               accept="application/pdf"
               @change="
                    fileError = '';
                    const file = $event.target.files[0];

                    if (file) {
                        if (file.type !== 'application/pdf') {
                            fileError = 'Only PDF files are allowed';
                            $event.target.value = '';
                        }

                        else if (file.size > 2 * 1024 * 1024) {
                            fileError = 'File must not exceed 2MB';
                            $event.target.value = '';
                        }
                    }
                "
               class="file:bg-blue-600 dark:file:bg-[#e17100] file:text-white text-white dark:file:text-black rounded-sm col-span-full">

        <p x-show="fileError"
           x-text="fileError"
           class="text-sm text-red-500">
        </p>

